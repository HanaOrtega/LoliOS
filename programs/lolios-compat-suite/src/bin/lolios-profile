#!/usr/bin/env python3
import argparse, json, os, re, tarfile, tempfile
from datetime import datetime
from pathlib import Path

STATE = Path(os.environ.get('LOLIOS_EXE_STATE_DIR', Path.home() / '.local/share/lolios/exe-launcher'))
APPS = STATE / 'apps'
BASE = Path(os.environ.get('LOLIOS_PREFIX_BASE', Path.home() / 'Games/LoliOS'))
SCHEMA_VERSION = 5
MAX_PACKAGE_BYTES = 2 * 1024 * 1024 * 1024
MAX_MEMBER_BYTES = 1024 * 1024 * 1024
APPS.mkdir(parents=True, exist_ok=True)
BASE.mkdir(parents=True, exist_ok=True)


def san(value):
    return re.sub(r'[^A-Za-z0-9._-]+', '_', str(value)).strip('_') or 'windows-app'


def infer_category(data):
    explicit = data.get('category') or data.get('profile_category')
    if explicit in ['game', 'app']:
        return explicit
    text = ' '.join(str(data.get(k, '')) for k in ['name', 'display_name', 'main_exe', 'installer_exe', 'preset', 'mode']).lower()
    app_hints = ['office', 'word', 'excel', 'photoshop', 'illustrator', 'autocad', 'notepad', 'setup', 'installer', 'runtime', 'redist', 'app-', 'vb6', 'dotnet', 'portable', 'tool']
    game_hints = ['game', 'steam', 'gog', 'epic', 'launcher', 'dx12', 'dxvk', 'vkd3d', 'unity', 'unreal']
    if any(h in text for h in app_hints):
        return 'app'
    if any(h in text for h in game_hints):
        return 'game'
    return 'game'


def profile_path(name):
    return APPS / san(name) / 'profile.json'


def read_profile(name):
    path = profile_path(name)
    if not path.exists():
        raise SystemExit(f'profile not found: {name}')
    return json.load(open(path, encoding='utf-8'))


def write_profile(name, data, overwrite=True):
    path = profile_path(name)
    if path.exists() and not overwrite:
        raise SystemExit(f'profile already exists: {name}')
    path.parent.mkdir(parents=True, exist_ok=True)
    json.dump(data, open(path, 'w', encoding='utf-8'), indent=2, ensure_ascii=False)


def migrate_json(data):
    old = int(data.get('schema_version', 1) or 1)
    history = data.setdefault('migrated_from', [])
    if 'exe' in data and not data.get('main_exe'):
        data['main_exe'] = data['exe']
    if 'prefix' in data and not data.get('wine_prefix'):
        data['wine_prefix'] = data['prefix']
    data.setdefault('name', san(data.get('display_name') or Path(data.get('main_exe', 'app')).stem))
    data['name'] = san(data['name'])
    data.setdefault('display_name', data['name'])
    data.setdefault('category', infer_category(data))
    data.setdefault('runner', 'auto')
    data.setdefault('arch', 'win64')
    data.setdefault('main_exe', '')
    data.setdefault('installer_exe', '')
    data.setdefault('wine_prefix', str(BASE / data['name'] / 'prefix'))
    data.setdefault('proton_compat_data', str(BASE / data['name'] / 'compatdata'))
    data.setdefault('features', {})
    for key, default in {'dxvk': True, 'vkd3d': False, 'gamemode': True, 'mangohud': False, 'gamescope': False, 'gamescope_args': '-f', 'prime': 'auto'}.items():
        data['features'].setdefault(key, default)
    for key, default in {
        'env': {}, 'winetricks': [], 'custom_runtimes': [], 'installed_runtimes': [],
        'runtime_policy': 'missing-only', 'executables': [], 'dll_overrides': {},
        'registry_patches': [], 'sandbox': {'mode': 'normal', 'allow_paths': []},
        'path_mounts': [], 'network': {'enabled': True, 'mode': 'online'}, 'locale': {},
        'virtual_desktop': {'enabled': False, 'width': 1280, 'height': 720},
        'audio_profile': {}, 'controller_profile': {}, 'font_profile': {}, 'codec_profile': {},
        'mangohud_profile': {}, 'gamescope_profile': {}, 'file_identity': {}, 'quarantine': {},
        'last_known_good': {}, 'launch_history': []
    }.items():
        data.setdefault(key, default)
    if data.get('main_exe') and not any(item.get('id') == 'main' for item in data['executables']):
        data['executables'].append({'id': 'main', 'name': data.get('display_name', 'Main'), 'path': data['main_exe'], 'default': True})
    if old != SCHEMA_VERSION and old not in history:
        history.append(old)
    data['schema_version'] = SCHEMA_VERSION
    return data


def validate_json(data):
    issues = []
    for key in ['name', 'main_exe', 'wine_prefix', 'runner', 'features', 'category']:
        if key not in data or data.get(key) in [None, '']:
            issues.append(f'missing:{key}')
    if data.get('category') not in ['game', 'app']:
        issues.append('bad:category')
    if data.get('runner') not in ['auto', 'wine', 'proton']:
        issues.append('bad:runner')
    if data.get('arch') not in ['win32', 'win64']:
        issues.append('bad:arch')
    if data.get('main_exe') and not Path(data['main_exe']).exists():
        issues.append('main_exe_missing')
    if not isinstance(data.get('features'), dict):
        issues.append('bad:features')
    if not isinstance(data.get('winetricks'), list):
        issues.append('bad:winetricks')
    return issues


def cmd_validate(args):
    data = migrate_json(read_profile(args.profile))
    issues = validate_json(data)
    print(json.dumps({'ok': not issues, 'issues': issues, 'schema_version': data.get('schema_version'), 'category': data.get('category')}, indent=2, ensure_ascii=False))


def cmd_migrate(args):
    data = migrate_json(read_profile(args.profile))
    write_profile(args.profile, data)
    print('migrated')


def cmd_migrate_all(args):
    for path in sorted(APPS.glob('*/profile.json')):
        name = path.parent.name
        try:
            write_profile(name, migrate_json(json.load(open(path, encoding='utf-8'))))
            print(name)
        except Exception as exc:
            print(f'BAD {name}: {exc}')


def cmd_doctor(args):
    data = migrate_json(read_profile(args.profile))
    write_profile(args.profile, data)
    issues = validate_json(data)
    print(json.dumps({'fixed_schema': True, 'ok': not issues, 'issues': issues, 'category': data.get('category')}, indent=2, ensure_ascii=False))


def safe_extract(tar, dest):
    dest = dest.resolve()
    total = 0
    for member in tar.getmembers():
        if member.issym() or member.islnk():
            raise SystemExit('unsafe package: links are not allowed')
        if member.name.startswith('/') or '..' in Path(member.name).parts:
            raise SystemExit('unsafe package: absolute or parent path')
        total += member.size
        if member.size > MAX_MEMBER_BYTES or total > MAX_PACKAGE_BYTES:
            raise SystemExit('unsafe package: size limit exceeded')
        target = (dest / member.name).resolve()
        if not str(target).startswith(str(dest)):
            raise SystemExit('unsafe package: path traversal')
    tar.extractall(dest)


def cmd_export(args):
    data = migrate_json(read_profile(args.profile))
    out = Path(args.output or f'{san(args.profile)}.loliospkg').resolve()
    tmp_root = Path(tempfile.mkdtemp())
    tmp = tmp_root / san(args.profile)
    tmp.mkdir(parents=True)
    (tmp / 'manifest.json').write_text(json.dumps({'loliospkg_version': 1, 'profile': san(args.profile), 'category': data.get('category'), 'created_at': datetime.utcnow().isoformat() + 'Z', 'contains_prefix': False}, indent=2), encoding='utf-8')
    (tmp / 'profile.json').write_text(json.dumps(data, indent=2, ensure_ascii=False), encoding='utf-8')
    logs = tmp / 'logs'
    logs.mkdir()
    for log in (APPS / san(args.profile) / 'logs').glob('*.log'):
        redacted = log.read_text(errors='ignore').replace(str(Path.home()), '$HOME')
        (logs / log.name).write_text(redacted, encoding='utf-8')
    with tarfile.open(out, 'w:xz') as tar:
        tar.add(tmp, arcname=san(args.profile))
    print(out)


def cmd_import(args):
    package = Path(args.package)
    if not package.exists() or package.stat().st_size > MAX_PACKAGE_BYTES:
        raise SystemExit('invalid or too large package')
    dest = STATE / 'imports' / datetime.utcnow().strftime('%Y%m%d-%H%M%S')
    dest.mkdir(parents=True)
    with tarfile.open(package) as tar:
        safe_extract(tar, dest)
    manifests = list(dest.glob('*/manifest.json'))
    profiles = list(dest.glob('*/profile.json'))
    if not manifests or not profiles:
        raise SystemExit('invalid package: manifest.json and profile.json are required')
    manifest = json.load(open(manifests[0], encoding='utf-8'))
    if manifest.get('loliospkg_version') != 1:
        raise SystemExit('unsupported loliospkg version')
    data = migrate_json(json.load(open(profiles[0], encoding='utf-8')))
    if args.category:
        data['category'] = args.category
    name = san(args.name or data.get('name') or manifest.get('profile'))
    data['name'] = name
    if profile_path(name).exists() and not args.force:
        raise SystemExit(f'profile exists: {name}; use --force to overwrite')
    write_profile(name, data, overwrite=True)
    print(name)


def cmd_set_category(args):
    data = migrate_json(read_profile(args.profile))
    data['category'] = args.category
    write_profile(args.profile, data)
    print(json.dumps({'profile': args.profile, 'category': args.category}, indent=2))


def main():
    parser = argparse.ArgumentParser(description='LoliOS profile manager')
    sub = parser.add_subparsers(dest='cmd', required=True)
    for cmd, func in [('validate', cmd_validate), ('migrate', cmd_migrate), ('doctor', cmd_doctor)]:
        p = sub.add_parser(cmd)
        p.add_argument('profile')
        p.set_defaults(func=func)
    sub.add_parser('migrate-all').set_defaults(func=cmd_migrate_all)
    p = sub.add_parser('export')
    p.add_argument('profile')
    p.add_argument('--output')
    p.set_defaults(func=cmd_export)
    p = sub.add_parser('import')
    p.add_argument('package')
    p.add_argument('--name')
    p.add_argument('--force', action='store_true')
    p.add_argument('--category', choices=['game', 'app'])
    p.set_defaults(func=cmd_import)
    p = sub.add_parser('set-category')
    p.add_argument('profile')
    p.add_argument('category', choices=['game', 'app'])
    p.set_defaults(func=cmd_set_category)
    args = parser.parse_args()
    args.func(args)


if __name__ == '__main__':
    main()
