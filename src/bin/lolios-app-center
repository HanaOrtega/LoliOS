#!/usr/bin/env python3
import json
import os
import pathlib
import shutil
import subprocess
import sys

sys.path.insert(0, '/usr/lib/lolios')
try:
    from lolios_guard import require_lolios
except Exception:
    def require_lolios(tool_name='LoliOS tool'):
        if os.environ.get('LOLIOS_DEV_ALLOW_NON_LOLIOS') == '1':
            return
        if pathlib.Path('/etc/lolios-live').exists() or pathlib.Path('/usr/share/lolios').exists() or pathlib.Path('/opt/lolios').exists():
            return
        print(f'{tool_name} is only supported on LoliOS. Set LOLIOS_DEV_ALLOW_NON_LOLIOS=1 for repo development.', file=sys.stderr)
        raise SystemExit(72)

require_lolios('LoliOS App Center')

STATE = pathlib.Path(os.environ.get('LOLIOS_EXE_STATE_DIR', pathlib.Path.home() / '.local/share/lolios/exe-launcher'))
APPS = STATE / 'apps'
LAUNCHER = shutil.which('lolios-exe-launcher') or '/usr/local/bin/lolios-exe-launcher'
PROFILE_TOOL = shutil.which('lolios-profile') or '/usr/local/bin/lolios-profile'
ADV = shutil.which('lolios-advanced-compat') or '/usr/local/bin/lolios-advanced-compat'
NEXT = shutil.which('lolios-next-compat') or '/usr/local/bin/lolios-next-compat'
IMPORTER = shutil.which('lolios-import-games') or '/usr/local/bin/lolios-import-games'
ICON_EXTRACT = shutil.which('lolios-icon-extract') or '/usr/local/bin/lolios-icon-extract'


def run_capture(cmd):
    try:
        return subprocess.run(cmd, text=True, capture_output=True)
    except FileNotFoundError as exc:
        return subprocess.CompletedProcess(cmd, 127, '', str(exc))


def run_async(cmd):
    try:
        subprocess.Popen(cmd)
        return True
    except FileNotFoundError:
        return False


def list_profiles():
    try:
        return json.loads(subprocess.check_output([LAUNCHER, '--list-json', '--category', 'app'], text=True) or '[]')
    except Exception:
        return []


def logs_dir(name):
    return APPS / name / 'logs'


class AppCenter:
    def __init__(self):
        import tkinter as tk
        from tkinter import ttk
        self.tk = tk
        self.ttk = ttk
        self.profiles = []
        self.root = tk.Tk()
        self.root.title('LoliOS App Center')
        self.root.geometry('1280x760')
        self.build_ui()
        self.refresh()

    def build_ui(self):
        tk = self.tk
        ttk = self.ttk
        main = ttk.Panedwindow(self.root, orient=tk.HORIZONTAL)
        main.pack(fill=tk.BOTH, expand=True, padx=8, pady=8)
        left = ttk.Frame(main); right = ttk.Frame(main)
        main.add(left, weight=3); main.add(right, weight=2)
        top = ttk.Frame(left); top.pack(fill=tk.X, pady=(0, 6))
        ttk.Button(top, text='Refresh', command=self.refresh).pack(side=tk.LEFT)
        ttk.Button(top, text='Install EXE', command=self.install_exe).pack(side=tk.LEFT, padx=4)
        ttk.Button(top, text='Add portable EXE', command=self.add_portable).pack(side=tk.LEFT)
        ttk.Button(top, text='Import folder', command=self.import_folder).pack(side=tk.LEFT, padx=4)
        self.tree = ttk.Treeview(left, columns=('runner', 'sandbox', 'exe'), show='headings')
        for col, title, width in [('runner', 'Runner', 90), ('sandbox', 'Sandbox', 90), ('exe', 'Application / EXE', 760)]:
            self.tree.heading(col, text=title); self.tree.column(col, width=width)
        self.tree.pack(fill=tk.BOTH, expand=True)
        self.tree.bind('<<TreeviewSelect>>', lambda _event: self.load_details())
        tabs = ttk.Notebook(right); tabs.pack(fill=tk.BOTH, expand=True)
        self.details = tk.Text(tabs, wrap='word'); tabs.add(self.details, text='Profile')
        run_tab = ttk.Frame(tabs); install_tab = ttk.Frame(tabs); compat_tab = ttk.Frame(tabs); security_tab = ttk.Frame(tabs); tools_tab = ttk.Frame(tabs)
        tabs.add(run_tab, text='Run'); tabs.add(install_tab, text='Install/Backup'); tabs.add(compat_tab, text='Runtime'); tabs.add(security_tab, text='Security'); tabs.add(tools_tab, text='Tools')
        self.add_buttons(run_tab, [('Run app', self.run_app), ('Repair profile', self.repair), ('Rescan EXE', self.rescan), ('Preflight', self.preflight), ('Validate profile', self.validate), ('Open logs', self.open_logs)])
        self.add_buttons(install_tab, [('Snapshot', self.snapshot), ('Rollback', self.rollback), ('Export .loliospkg', self.export_package), ('Uninstall profile', self.uninstall)])
        self.add_buttons(compat_tab, [('App preset: dotnet', lambda: self.apply_preset('launcher')), ('App preset: legacy', lambda: self.apply_preset('legacy')), ('Apply fix', self.apply_fix), ('Runtime graph', self.runtime_graph), ('Check conflicts', self.check_conflicts), ('Crash analysis', self.crash_analysis)])
        self.add_buttons(security_tab, [('Sandbox off', lambda: self.set_value('sandbox.mode', 'off')), ('Sandbox normal', lambda: self.set_value('sandbox.mode', 'normal')), ('Sandbox strict', lambda: self.set_value('sandbox.mode', 'strict')), ('Network on', lambda: self.set_value('network.enabled', 'true')), ('Network off', lambda: self.set_value('network.enabled', 'false')), ('DLL override', self.dll_override), ('Registry patch', self.registry_patch)])
        self.add_buttons(tools_tab, [('Icon extract', self.icon_extract), ('Open profile folder', self.open_profile_folder), ('Mark as game', lambda: self.set_category('game')), ('Show JSON', self.show_json)])

    def add_buttons(self, parent, buttons):
        for label, callback in buttons:
            self.ttk.Button(parent, text=label, command=callback).pack(anchor='w', fill='x', padx=8, pady=4)
    def current_name(self):
        selection = self.tree.selection(); return selection[0] if selection else None
    def current_profile(self):
        name = self.current_name(); return next((p for p in self.profiles if p.get('name') == name), None) if name else None
    def refresh(self):
        self.profiles = list_profiles(); self.tree.delete(*self.tree.get_children())
        for profile in self.profiles:
            name = profile.get('name', '?'); sandbox = profile.get('sandbox', {}).get('mode', '?'); label = f"{profile.get('display_name', name)} — {profile.get('main_exe', '')}"
            self.tree.insert('', self.tk.END, iid=name, values=(profile.get('runner', 'auto'), sandbox, label))
        self.load_details()
    def load_details(self):
        self.details.delete('1.0', self.tk.END); profile = self.current_profile()
        if profile: self.details.insert(self.tk.END, json.dumps(profile, indent=2, ensure_ascii=False))
    def require_profile(self):
        from tkinter import messagebox
        name = self.current_name()
        if not name:
            messagebox.showwarning('LoliOS App Center', 'Select an application profile first.'); return None
        return name
    def ask(self, title, prompt, default=''):
        from tkinter import simpledialog
        return simpledialog.askstring(title, prompt, initialvalue=default)
    def confirm(self, title, message):
        from tkinter import messagebox
        return messagebox.askyesno(title, message)
    def show_result(self, title, result):
        win = self.tk.Toplevel(self.root); win.title(title); win.geometry('900x560')
        text = self.tk.Text(win, wrap='word'); text.pack(fill=self.tk.BOTH, expand=True)
        body = result.stdout or ''
        if result.stderr: body += '\n--- stderr ---\n' + result.stderr
        text.insert(self.tk.END, body or f'exit code: {result.returncode}'); self.refresh()
    def run_show(self, title, cmd): self.show_result(title, run_capture(cmd))
    def install_exe(self):
        from tkinter import filedialog
        exe = filedialog.askopenfilename(title='Install Windows application', filetypes=[('Windows executables', '*.exe'), ('All files', '*')])
        if exe: run_async([LAUNCHER, 'install', exe, '--category', 'app'])
    def add_portable(self):
        from tkinter import filedialog
        exe = filedialog.askopenfilename(title='Add portable Windows application', filetypes=[('Windows executables', '*.exe'), ('All files', '*')])
        if exe: run_async([LAUNCHER, exe, '--category', 'app'])
    def import_folder(self):
        from tkinter import filedialog
        folder = filedialog.askdirectory(title='Import folder with Windows applications')
        if folder: self.run_show('Import folder', [IMPORTER, '--folder', folder])
    def run_app(self):
        name = self.require_profile()
        if name: run_async([LAUNCHER, '--profile', name])
    def repair(self):
        name = self.require_profile()
        if name: run_async([LAUNCHER, '--repair', '--profile', name])
    def rescan(self):
        name = self.require_profile()
        if name: self.run_show('Rescan', [LAUNCHER, '--rescan', '--profile', name])
    def preflight(self):
        name = self.require_profile()
        if name: self.run_show('Preflight', [LAUNCHER, '--preflight', '--profile', name])
    def validate(self):
        name = self.require_profile()
        if name: self.run_show('Validate', [PROFILE_TOOL, 'validate', name])
    def snapshot(self):
        name = self.require_profile()
        if name: self.run_show('Snapshot', [ADV, 'snapshot', name, '--reason', 'app-center'])
    def rollback(self):
        name = self.require_profile()
        if name and self.confirm('Rollback', f'Rollback {name} to latest snapshot?'): self.run_show('Rollback', [ADV, 'rollback', name])
    def export_package(self):
        name = self.require_profile()
        if name: self.run_show('Export .loliospkg', [PROFILE_TOOL, 'export', name])
    def uninstall(self):
        name = self.require_profile()
        if name and self.confirm('Uninstall profile', f'Remove application profile {name}?'): self.run_show('Uninstall profile', [NEXT, 'uninstall', name])
    def apply_preset(self, preset):
        name = self.require_profile()
        if name: self.run_show('Apply preset', [LAUNCHER, '--apply-preset', name, preset])
    def apply_fix(self):
        name = self.require_profile(); fix = self.ask('Apply fix', 'Fix name, e.g. install-dotnet, install-xact, disable-esync', 'install-dotnet') if name else None
        if name and fix: self.run_show('Apply fix', [NEXT, 'safe-apply-fix', name, fix])
    def runtime_graph(self):
        name = self.require_profile()
        if name: self.run_show('Runtime graph', [NEXT, 'runtime-graph', name])
    def check_conflicts(self):
        name = self.require_profile()
        if name: self.run_show('Check conflicts', [NEXT, 'check-conflicts', name])
    def crash_analysis(self):
        name = self.require_profile()
        if name: self.run_show('Crash analysis', [NEXT, 'crash-analyze', name])
    def set_value(self, key, value):
        name = self.require_profile()
        if name: self.run_show('Set profile value', [LAUNCHER, '--set', name, key, value])
    def set_category(self, category):
        name = self.require_profile()
        if name: self.run_show('Set category', [PROFILE_TOOL, 'set-category', name, category])
    def dll_override(self):
        name = self.require_profile()
        if not name: return
        dll = self.ask('DLL override', 'DLL name, e.g. winhttp, dinput8, dxgi', 'winhttp')
        value = self.ask('DLL override', 'Override value, e.g. native,builtin or builtin', 'native,builtin') if dll else None
        if value: self.run_show('DLL override', [NEXT, 'dll-set', name, dll, value])
    def registry_patch(self):
        name = self.require_profile(); patch = self.ask('Registry patch', 'Patch name, e.g. win10, win7, virtual-desktop-1080p', 'win10') if name else None
        if name and patch: self.run_show('Registry patch', [NEXT, 'reg-apply', name, patch])
    def icon_extract(self):
        name = self.require_profile()
        if name: self.run_show('Icon extract', [ICON_EXTRACT, name])
    def open_logs(self):
        name = self.require_profile()
        if name:
            folder = logs_dir(name); folder.mkdir(parents=True, exist_ok=True); run_async(['xdg-open', str(folder)])
    def open_profile_folder(self):
        name = self.require_profile()
        if name:
            folder = APPS / name; folder.mkdir(parents=True, exist_ok=True); run_async(['xdg-open', str(folder)])
    def show_json(self): self.show_result('App Center JSON', subprocess.CompletedProcess(['internal-json'], 0, json.dumps(self.profiles, indent=2, ensure_ascii=False), ''))
    def mainloop(self): self.root.mainloop()


def fallback_cli():
    profiles = list_profiles()
    if not profiles:
        print('No Windows application profiles found.'); return 0
    print('LoliOS App Center')
    for idx, profile in enumerate(profiles, 1): print(f"{idx}) {profile.get('display_name', profile.get('name'))} [{profile.get('runner','auto')}] {profile.get('main_exe','')}")
    return 0


def main():
    if '--json' in sys.argv:
        print(json.dumps(list_profiles(), indent=2, ensure_ascii=False)); return
    try:
        AppCenter().mainloop()
    except Exception as exc:
        print(f'GUI unavailable or failed: {exc}', file=sys.stderr)
        raise SystemExit(fallback_cli())

if __name__ == '__main__':
    main()
